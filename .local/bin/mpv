#!/bin/bash
# ============================================================================
# MPV WRAPPER WITH LF FILE BROWSER INTEGRATION
# ============================================================================
# Purpose:
#   This wrapper enhances mpv to work seamlessly with launchers (rofi, dmenu)
#   by providing a file browser (lf) when launched without arguments. This solves
#   the problem of launchers only passing the command name without file arguments.
#
# Behavior:
#   - WITH arguments (e.g., 'mpv video.mp4'): Passes through to real mpv
#   - WITHOUT arguments (from launcher): Opens lf file browser for selection
#
# Dependencies:
#   - mpv: The actual video player (/usr/bin/mpv)
#   - lf: Terminal file manager for browsing/selecting videos
#   - alacritty: Terminal emulator to display lf
#
# Usage Examples:
#   From launcher:  Select 'mpv' → Opens lf → Navigate to video → Enter
#   From terminal:  mpv ~/Videos/movie.mp4  (works normally)
#   With options:   mpv --volume=50 file.mp4  (all options pass through)
#
# Installation:
#   Place in /usr/local/bin/mpv to shadow the system mpv
#   Ensure it's executable: chmod +x /usr/local/bin/mpv
#
# Related Files:
#   ~/.config/mpv/mpv.conf - MPV configuration (resume, history, etc.)
#   ~/.config/mpv/input.conf - Custom keybindings
#   ~/.config/bspwm/polybar-autohide.sh - Auto-hides polybar in monocle
#
# Troubleshooting:
#   - If lf doesn't open: Check alacritty is installed
#   - If mpv doesn't play: Verify /usr/bin/mpv exists
#   - Check logs: ~/.local/state/mpv/watch_history.jsonl
#
# Author: System configuration for pentaxis93
# Date: September 2024
# ============================================================================

# If arguments provided, pass through to real mpv
if [ $# -gt 0 ]; then
    exec /usr/bin/mpv "$@"
fi

# No arguments - open lf for file selection
# Determine starting directory (prefer Videos, then Downloads, then home)
if [ -d "$HOME/Videos" ] && [ "$(ls -A "$HOME/Videos" 2>/dev/null)" ]; then
    START_DIR="$HOME/Videos"
elif [ -d "$HOME/Downloads" ]; then
    START_DIR="$HOME/Downloads"
else
    START_DIR="$HOME"
fi

# Create temporary file for selection
SELECTION_FILE=$(mktemp /tmp/lf-mpv-XXXXXX)

# Create a wrapper script for lf that will handle the selection
cat > /tmp/lf-select-video.sh << 'LFSCRIPT'
#!/bin/bash
SELECTION_FILE="$1"
START_DIR="$2"

# Create lf config that saves selection on Enter
mkdir -p /tmp/lf-mpv-config
cat > /tmp/lf-mpv-config/lfrc << 'CONFIG'
# Override enter to select file and exit
cmd select-and-exit &{{
    if [ -f "$f" ]; then
        echo "$f" > SELECTION_FILE_PLACEHOLDER
        lf -remote "send $id quit"
    fi
}}
map <enter> select-and-exit
CONFIG

# Replace placeholder with actual file path
sed -i "s|SELECTION_FILE_PLACEHOLDER|$SELECTION_FILE|" /tmp/lf-mpv-config/lfrc

# Run lf with custom config
cd "$START_DIR"
lf -config /tmp/lf-mpv-config/lfrc

# Clean up
rm -rf /tmp/lf-mpv-config
LFSCRIPT

chmod +x /tmp/lf-select-video.sh

# Open lf in Alacritty for file selection
alacritty -T "Select video for mpv" -e /tmp/lf-select-video.sh "$SELECTION_FILE" "$START_DIR"

# Check if a file was selected
if [ -f "$SELECTION_FILE" ] && [ -s "$SELECTION_FILE" ]; then
    SELECTED_FILE=$(cat "$SELECTION_FILE")
    if [ -f "$SELECTED_FILE" ]; then
        # Launch mpv with the selected file
        exec /usr/bin/mpv "$SELECTED_FILE"
    fi
fi

# Clean up temporary files
rm -f "$SELECTION_FILE" /tmp/lf-select-video.sh