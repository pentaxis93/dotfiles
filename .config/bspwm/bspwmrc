#! /bin/sh

# ============================================================================
# KEYBOARD REMAPPING
# ============================================================================
# Load custom key remappings (PrtSc → Super key)
# This must happen early in the startup sequence before other keybindings
[ -f ~/.Xmodmap ] && xmodmap ~/.Xmodmap

pgrep -x sxhkd > /dev/null || sxhkd &

# Launch polybar
$HOME/.config/polybar/launch.sh

# ============================================================================
# POLYBAR AUTO-HIDE DAEMON
# ============================================================================
# Purpose: Automatically hide polybar when watching videos in monocle mode
# How it works:
#   1. Monitors BSPWM events (focus changes, layout switches)
#   2. When mpv/vlc is focused in monocle mode → hides polybar
#   3. When leaving monocle or focusing other windows → shows polybar
#
# The daemon is self-healing and will restart if bspc disconnects.
# Log file: /tmp/polybar-autohide.log (for debugging)
# Manual toggle: Super+B (defined in sxhkdrc)
#
# Why nohup: Ensures the daemon survives after bspwmrc exits
# Why kill first: Prevents multiple instances from accumulating on reload
# Why sleep: Gives the old process time to fully terminate

# Kill any existing instances to prevent duplicates
pkill -f polybar-autohide.sh 2>/dev/null
sleep 0.5  # Brief pause to ensure clean termination

# Start the daemon with nohup so it survives parent shell exit
nohup "$HOME/.config/bspwm/polybar-autohide.sh" >/dev/null 2>&1 &

bspc monitor -d I II III IV V VI VII VIII IX X

bspc config border_width         2
bspc config window_gap           0

# Gruvbox Dark Hard border colors
bspc config focused_border_color  "#8ec07c"  # Bright cyan (gentler)
bspc config normal_border_color   "#3c3836"  # Dark gray
bspc config active_border_color   "#8ec07c"  # Bright cyan
bspc config presel_feedback_color "#b8bb26"  # Bright green
bspc config top_padding          24

bspc config split_ratio          0.5
bspc config borderless_monocle   true
bspc config gapless_monocle      true

bspc rule -a Gimp desktop='^8' state=floating follow=on
bspc rule -a Chromium desktop='^2'
bspc rule -a mplayer2 state=floating
bspc rule -a Kupfer.py focus=on
bspc rule -a Screenkey manage=off
