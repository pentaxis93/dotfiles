{
  "model": "opus",
  "outputStyle": "Explanatory",
  "permissions": {
    "allow": [
      "# ============================================================================",
      "# GREEN ZONE: Safe, read-only operations",
      "# These commands gather information without modifying the system",
      "# ============================================================================",

      "# MCP Tools",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",

      "# Basic information commands",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(hostname)",
      "Bash(date)",
      "Bash(env)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(command:*)",

      "# Process and system info",
      "Bash(ps:*)",
      "Bash(pgrep:*)",
      "Bash(pidof:*)",
      "Bash(top:*)",
      "Bash(htop:*)",
      "Bash(btop:*)",
      "Bash(free:*)",
      "Bash(df:*)",
      "Bash(du:*)",
      "Bash(uname:*)",
      "Bash(uptime)",
      "Bash(systemctl status:*)",
      "Bash(journalctl:*)",

      "# File inspection (read-only)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(less:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",

      "# Text processing",
      "Bash(awk:*)",
      "Bash(sed -n:*)",
      "Bash(cut:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(tr:*)",
      "Bash(xargs:*)",

      "# Package queries (no installation)",
      "Bash(pacman -Q:*)",
      "Bash(pacman -Qi:*)",
      "Bash(pacman -Ql:*)",
      "Bash(pacman -Ss:*)",
      "Bash(yay -Q:*)",
      "Bash(yay -Qi:*)",
      "Bash(npm list:*)",
      "Bash(npm root:*)",

      "# Git status (no modifications)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git config --get:*)",
      "Bash(dots status:*)",
      "Bash(dots log:*)",
      "Bash(dots diff:*)",

      "# System queries",
      "Bash(fc-list:*)",
      "Bash(locale:*)",
      "Bash(gsettings get:*)",
      "Bash(xfconf-query -l:*)",
      "Bash(xprop:*)",
      "Bash(xwininfo:*)",
      "Bash(bspc query:*)",

      "# Claude Code operations",
      "Bash(claude --version)",
      "Bash(claude config list:*)",
      "Bash(claude config get:*)",

      "# Read access to system files",
      "Read(~/.config/**)",
      "Read(~/.local/**)",
      "Read(/usr/share/doc/**)",
      "Read(/usr/share/fish/**)",
      "Read(/etc/**)",
      "Read(/proc/**)",
      "Read(/sys/class/backlight/**)",
      "Read(/tmp/**)",

      "# Web access",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ]
  }
}