{
  "model": "opus",
  "outputStyle": "Explanatory",
  "permissions": {
    "allow": [
      "# ============================================================================",
      "# GREEN ZONE: Safe, read-only operations",
      "# These commands gather information without modifying the system",
      "# ============================================================================",

      "# MCP Tools",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",

      "# Basic information commands",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(hostname)",
      "Bash(date)",
      "Bash(env)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(command:*)",

      "# Process and system info",
      "Bash(ps:*)",
      "Bash(pgrep:*)",
      "Bash(pidof:*)",
      "Bash(top:*)",
      "Bash(htop:*)",
      "Bash(btop:*)",
      "Bash(free:*)",
      "Bash(df:*)",
      "Bash(du:*)",
      "Bash(uname:*)",
      "Bash(uptime)",
      "Bash(systemctl status:*)",
      "Bash(journalctl:*)",

      "# File inspection (read-only)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(less:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",

      "# Text processing",
      "Bash(awk:*)",
      "Bash(sed -n:*)",
      "Bash(cut:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(tr:*)",
      "Bash(xargs:*)",

      "# Package queries (no installation)",
      "Bash(pacman -Q:*)",
      "Bash(pacman -Qi:*)",
      "Bash(pacman -Ql:*)",
      "Bash(pacman -Ss:*)",
      "Bash(yay -Q:*)",
      "Bash(yay -Qi:*)",
      "Bash(npm list:*)",
      "Bash(npm root:*)",

      "# Git status (no modifications)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git config --get:*)",
      "Bash(dots status:*)",
      "Bash(dots log:*)",
      "Bash(dots diff:*)",

      "# System queries",
      "Bash(fc-list:*)",
      "Bash(locale:*)",
      "Bash(gsettings get:*)",
      "Bash(xfconf-query -l:*)",
      "Bash(xprop:*)",
      "Bash(xwininfo:*)",
      "Bash(bspc query:*)",

      "# Claude Code operations",
      "Bash(claude --version)",
      "Bash(claude config list:*)",
      "Bash(claude config get:*)",

      "# Read access to system files",
      "Read(~/.config/**)",
      "Read(~/.local/**)",
      "Read(/usr/share/doc/**)",
      "Read(/usr/share/fish/**)",
      "Read(/etc/**)",
      "Read(/proc/**)",
      "Read(/sys/class/backlight/**)",
      "Read(/tmp/**)",

      "# Web access",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:raw.githubusercontent.com)",

      "# ============================================================================",
      "# YELLOW ZONE: General user-level modifications",
      "# Commands that work with user files/processes across any project",
      "# ============================================================================",

      "# Process control (user processes only)",
      "Bash(pkill:*)",
      "Bash(killall:*)",
      "Bash(kill:*)",

      "# File permissions (user files)",
      "Bash(chmod:*)",

      "# Common development tools",
      "Bash(make:*)",
      "Bash(npm:*)",
      "Bash(cargo:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(node:*)",
      "Bash(go:*)",
      "Bash(rustc:*)",
      "Bash(gcc:*)",
      "Bash(g++:*)",
      "Bash(clang:*)",

      "# Testing and linting",
      "Bash(pytest:*)",
      "Bash(jest:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(black:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(clippy:*)",

      "# Build tools",
      "Bash(cmake:*)",
      "Bash(meson:*)",
      "Bash(ninja:*)",
      "Bash(gradle:*)",
      "Bash(mvn:*)",

      "# Version control (standard git operations)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git pull)",
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git stash:*)",
      "Bash(git reset:*)",
      "Bash(git clean:*)",
      "Bash(gh:*)",

      "# Terminal multiplexers",
      "Bash(tmux:*)",
      "Bash(screen:*)",

      "# Common text processing with modifications",
      "Bash(sed:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",

      "# Archive operations",
      "Bash(tar:*)",
      "Bash(zip:*)",
      "Bash(unzip:*)",
      "Bash(7z:*)",

      "# Download tools",
      "Bash(curl:*)",
      "Bash(wget:*)",

      "# Claude Code self-management",
      "Bash(claude config set:*)",
      "Bash(claude login)",
      "Bash(claude update)"
    ]
  },
  "env": {
    "EDITOR": "helix",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "BASH_MAX_OUTPUT_LENGTH": "50000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "8192",
    "USE_BUILTIN_RIPGREP": "1"
  }
}