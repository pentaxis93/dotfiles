{{- /*
  Alternate lf wrapper preserving the legacy 'lfcd' name + 'lc' alias.
*/ -}}
{{- $selection := index .themes $.active_theme.family $.active_theme.variant "selection" -}}
{{- $green := index .themes $.active_theme.family $.active_theme.variant "green" -}}
{{- $comment := index .themes $.active_theme.family $.active_theme.variant "bright_black" -}}
{{- $sel_r := printf "0x%s" (substr 0 2 $selection) | atoi -}}
{{- $sel_g := printf "0x%s" (substr 2 4 $selection) | atoi -}}
{{- $sel_b := printf "0x%s" (substr 4 6 $selection) | atoi -}}
{{- $grn_r := printf "0x%s" (substr 0 2 $green) | atoi -}}
{{- $grn_g := printf "0x%s" (substr 2 4 $green) | atoi -}}
{{- $grn_b := printf "0x%s" (substr 4 6 $green) | atoi -}}
{{- $com_r := printf "0x%s" (substr 0 2 $comment) | atoi -}}
{{- $com_g := printf "0x%s" (substr 2 4 $comment) | atoi -}}
{{- $com_b := printf "0x%s" (substr 4 6 $comment) | atoi -}}
# lfcd — lf with directory change on exit.
local tmp dir ret
tmp=$(mktemp)

local promptfmt='\033[38;2;{{ $sel_r }};{{ $sel_g }};{{ $sel_b }}m lf\033[0m:\033[38;2;{{ $grn_r }};{{ $grn_g }};{{ $grn_b }}m %w\033[0m\033[38;2;{{ $com_r }};{{ $com_g }};{{ $com_b }}m/%f\033[0m'

if [ $# -gt 0 ]; then
    command lf -last-dir-path="$tmp" -command "set promptfmt \"$promptfmt\"" "$@"
else
    command lf -last-dir-path="$tmp" -command "set promptfmt \"$promptfmt\""
fi
ret=$?

if [ -f "$tmp" ]; then
    dir=$(cat "$tmp")
    rm -f "$tmp"
    if [ -d "$dir" ] && [ "$dir" != "$(pwd)" ]; then
        cd "$dir" || return 1
    fi
fi

return $ret
