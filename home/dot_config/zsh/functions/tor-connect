# Start Tor anonymity proxy
# Semantic: Establish onion-routed circuit for anonymous connectivity

if systemctl --user is-active --quiet tor; then
    echo "✓ Tor already running"
    tor-status
    return 0
fi

echo "🧅 Starting Tor..."

systemctl --user start tor

if [ $? -ne 0 ]; then
    echo "✗ Failed to start Tor service"
    return 1
fi

# Wait for bootstrap (up to 60 seconds)
local timeout=60 elapsed=0
local log_file="$HOME/.local/share/tor/tor.log"

while [ $elapsed -lt $timeout ]; do
    if [ -f "$log_file" ] && grep -q "Bootstrapped 100%" "$log_file" 2>/dev/null; then
        break
    fi
    sleep 2
    elapsed=$((elapsed + 2))
done

if [ $elapsed -ge $timeout ]; then
    echo "⚠ Tor started but bootstrap timed out after ${timeout}s"
    echo "  Check: journalctl --user -u tor -n 20"
    return 1
fi

if sudo systemctl is-active --quiet goosevpn.service 2>/dev/null; then
    echo "✓ Tor connected (Tor over VPN)"
else
    echo "✓ Tor connected (standalone)"
fi

if command -v torsocks >/dev/null 2>&1 && command -v curl >/dev/null 2>&1; then
    local exit_ip
    exit_ip=$(torsocks curl -s https://check.torproject.org/api/ip 2>/dev/null | grep -oP '"IP":"\K[^"]+' | tail -1)
    [ -n "$exit_ip" ] && echo "  Exit IP: $exit_ip"
fi
