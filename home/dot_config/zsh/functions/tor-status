# Check Tor status, topology, and exit node
# Semantic: Observe the state of our anonymity circuits

if systemctl --user is-active --quiet tor; then
    local vpn_active=false
    if sudo systemctl is-active --quiet goosevpn.service 2>/dev/null; then
        vpn_active=true
    fi

    if [ "$vpn_active" = "true" ]; then
        echo "🧅 Tor Status: Connected (Tor over VPN)"
    else
        echo "🧅 Tor Status: Connected (standalone)"
    fi

    local uptime
    uptime=$(systemctl --user show -p ActiveEnterTimestamp --value tor 2>/dev/null)
    [ -n "$uptime" ] && echo "   Since: $uptime"

    if command -v torsocks >/dev/null 2>&1 && command -v curl >/dev/null 2>&1; then
        local exit_ip
        exit_ip=$(torsocks curl -s https://check.torproject.org/api/ip 2>/dev/null | grep -oP '"IP":"\K[^"]+' | tail -1)
        [ -n "$exit_ip" ] && echo "   Exit IP: $exit_ip"
    fi

    if [ "$vpn_active" = "true" ]; then
        local tun_ip
        tun_ip=$(ip addr show tun0 2>/dev/null | grep -oP 'inet \K[\d.]+')
        [ -n "$tun_ip" ] && echo "   VPN Tunnel: $tun_ip"
    fi

    echo "   SOCKS: 127.0.0.1:9050"
    echo "   Control: 127.0.0.1:9051"
else
    echo "🔴 Tor Status: Offline"

    if systemctl --user list-unit-files tor.service >/dev/null 2>&1; then
        echo "   Service: installed but inactive"
    else
        echo "   Service: not installed (run 'chezmoi apply')"
    fi

    echo "   Start with: torc"
fi
