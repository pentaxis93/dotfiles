# Disconnect from VPN via systemd service
# Semantic: Terminate secure tunnel and restore default route

if ! sudo systemctl is-active --quiet goosevpn.service; then
    echo "ℹ️  No active VPN connection"
    return 0
fi

echo "🔒 Disconnecting VPN..."

sudo systemctl stop goosevpn.service

if [ $? -eq 0 ]; then
    echo "✓ VPN disconnected"
else
    echo "✗ Failed to disconnect VPN"
    return 1
fi
