{{- /*
  Secrets auto-loading for zsh.
  Loads env files from ~/.local/state/secrets/env/ into the shell environment.
  Port of the fish conf.d/00-secrets hook.
*/ -}}

# Secrets Auto-Loading
# "Secrets flow into the environment like water into a vessel"
# Sourced once per shell from $HOME/.config/zsh/conf.d/.

if [ -d "$HOME/.local/state/secrets/env" ]; then
    for _secret_file in "$HOME/.local/state/secrets/env"/*(N); do
        [ -f "$_secret_file" ] && source "$_secret_file"
    done
    unset _secret_file
fi

# SSH Agent socket — managed by systemd user service ssh-agent.service.
# The export in ~/.zshrc handles this directly; no per-shell fallback needed.
