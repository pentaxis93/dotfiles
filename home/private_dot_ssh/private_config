# SSH Configuration
# Managed by chezmoi
#
# One software key per machine (~/.ssh/id_ed25519) authenticates every host —
# no hardware key in the daily path. The YubiKey is reserved for account 2FA
# and for logging in from machines you don't own; it stays authorized on these
# remotes but is never this machine's default SSH identity. IdentitiesOnly yes
# offers only the named key, avoiding auth-attempt exhaustion and key leakage.

Host babbie
    HostName 57.131.33.144
    User core
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

Host weforge
    HostName 162.19.220.109
    User core
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

Host git.weforge.build
    User git
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

Host github.com
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

Host *
    ServerAliveInterval 60
    ServerAliveCountMax 3
