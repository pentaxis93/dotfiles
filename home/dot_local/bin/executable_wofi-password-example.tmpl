#!/usr/bin/env bash
# Example: Password/secret input with hidden text

password=$(wofi --show dmenu --password --prompt "Enter Password:" --lines 1)

if [ -z "$password" ]; then
    exit 0
fi

# Use the password (example: pipe to a script)
# echo "$password" | your-auth-script.sh

# For demonstration (DON'T actually log passwords!)
notify-send "Password Input" "Password received (length: ${#password} chars)"
