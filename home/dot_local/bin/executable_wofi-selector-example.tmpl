#!/usr/bin/env bash
# Example: Present options to user and execute based on selection

options="Open Browser
Check VPN
Launch Terminal
Take Screenshot"

choice=$(printf '%s' "$options" | wofi --show dmenu --prompt "Quick Action:")

if [ -z "$choice" ]; then
    exit 0
fi

case "$choice" in
    "Open Browser")
        zen-browser &
        ;;
    "Check VPN")
        zsh -i -c "vps"
        ;;
    "Launch Terminal")
        alacritty &
        ;;
    "Take Screenshot")
        grim -g "$(slurp)" "$HOME/Pictures/screenshot-$(date +%Y%m%d-%H%M%S).png"
        ;;
esac
