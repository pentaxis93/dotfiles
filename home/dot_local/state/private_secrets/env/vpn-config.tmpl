{{- /* VPN Configuration Environment Variables */ -}}
# VPN Server Configuration
# These variables are loaded automatically when Zsh starts (via conf.d/00-secrets.zsh)

# Goose VPN Server Details
export VPN_SERVER="nl-7.goosevpn.com"
export VPN_PORT="443"
export VPN_PROTOCOL="tcp-client"

# VPN Configuration Paths
export VPN_CONFIG_FILE="$HOME/.config/openvpn/goosevpn.conf"
export VPN_AUTH_FILE="$HOME/.local/state/secrets/openvpn/goosevpn-auth"
