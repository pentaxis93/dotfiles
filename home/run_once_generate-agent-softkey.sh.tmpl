{{- if not .is_vps -}}
#!/bin/bash
# Generate this machine's software SSH key (~/.ssh/id_ed25519) if absent.
#
# This single per-device key authenticates every remote — GitHub, the VPSes,
# the WeForge git endpoint. ~/.ssh/config points every host at it. The YubiKey
# is not in the daily SSH path; it is reserved for account 2FA and for logging
# in from machines you don't own. The key is deliberately *not* chezmoi-managed:
# it is a per-host secret that must never enter the repository. This script only
# ensures it exists; the public half still has to be authorized on each remote
# by hand.
#
# Idempotent: regenerating would invalidate already-registered public keys, so
# an existing key is left untouched.

set -euo pipefail

key="$HOME/.ssh/id_ed25519"

if [ -f "$key" ]; then
    echo "✓ Software SSH key already present: $key"
    exit 0
fi

echo "🔑 Generating this machine's software SSH key (ed25519)..."
mkdir -p "$HOME/.ssh"
chmod 700 "$HOME/.ssh"
ssh-keygen -t ed25519 -N "" -f "$key" -C "pentaxis93@{{ .chezmoi.hostname }}"

echo "✓ Created $key"
echo ""
echo "  Authorize the PUBLIC half on every remote this machine reaches:"
echo "    $(cat "${key}.pub")"
echo ""
echo "    • GitHub  → https://github.com/settings/keys"
echo "    • babbie / weforge → append to ~core/.ssh/authorized_keys"
echo "    • git.weforge.build → register in the WeForge account"
{{- else -}}
#!/bin/bash
# The VPS's SSH config and keys are managed by babbie-ops, not dotfiles.
exit 0
{{- end -}}
